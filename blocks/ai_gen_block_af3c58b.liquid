{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  /* ===== BASE SECTION ===== */
  .pgrid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 80px 0 0;
    background-color: {{ block.settings.background_color }};
    overflow: hidden;
  }

  .pgrid-inner-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }

  /* ===== TAB NAVIGATION ===== */
  .pgrid-tabs-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 0;
    margin-bottom: 50px;
    position: relative;
  }

  .pgrid-tabs-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 300px;
    max-width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, {{ block.settings.tab_border_color }}, transparent);
  }

  .pgrid-tab-{{ ai_gen_id }} {
    background: none;
    border: none;
    padding: 16px 32px;
    font-size: {{ block.settings.tab_font_size }}px;
    font-weight: {{ block.settings.tab_font_weight }};
    color: {{ block.settings.tab_text_color }};
    text-transform: uppercase;
    letter-spacing: 2.5px;
    cursor: pointer;
    position: relative;
    transition: color 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    font-family: inherit;
  }

  .pgrid-tab-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 50%;
    width: 0;
    height: 2px;
    background: {{ block.settings.tab_active_color }};
    transition: width 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), left 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .pgrid-tab-{{ ai_gen_id }}:hover {
    color: {{ block.settings.tab_hover_color }};
  }

  .pgrid-tab-{{ ai_gen_id }}.active {
    color: {{ block.settings.tab_active_color }};
  }

  .pgrid-tab-{{ ai_gen_id }}.active::after {
    width: 100%;
    left: 0;
  }

  /* ===== TAB PANELS ===== */
  .pgrid-panel-{{ ai_gen_id }} {
    display: none;
    animation: pgridFadeIn-{{ ai_gen_id }} 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .pgrid-panel-{{ ai_gen_id }}.active {
    display: block;
  }

  @keyframes pgridFadeIn-{{ ai_gen_id }} {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ===== PRODUCT GRID ===== */
  .pgrid-products-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.products_per_row }}, 1fr);
    gap: {{ block.settings.product_gap }}px;
  }

  /* ===== PRODUCT CARD ===== */
  .pgrid-card-{{ ai_gen_id }} {
    position: relative;
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow 0.4s ease;
  }

  .pgrid-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
  }

  .pgrid-card-link-{{ ai_gen_id }} {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  /* ===== IMAGE ===== */
  .pgrid-img-wrap-{{ ai_gen_id }} {
    position: relative;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
    background: #f5f5f5;
    display: block;
  }

  .pgrid-img-wrap-{{ ai_gen_id }} img {
     display: block;
     width: 100%;
     height: 100%;
     object-fit: cover;
  }

  .pgrid-img-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.6s ease;
  }

  .pgrid-img-secondary-{{ ai_gen_id }} {
    position: absolute;
    inset: 0;
    opacity: 0;
  }

  .pgrid-card-{{ ai_gen_id }}:hover .pgrid-img-{{ ai_gen_id }}:first-child {
    transform: scale(1.06);
  }

  .pgrid-card-{{ ai_gen_id }}:hover .pgrid-img-secondary-{{ ai_gen_id }} {
    opacity: 1;
    transform: scale(1.06);
  }

  /* ===== QUICK ADD OVERLAY (inline overlay) ===== */
  .pgrid-quickadd-{{ ai_gen_id }} {
    position: absolute;
    bottom: -1px;
    left: -1px;
    right: -1px;
    background: rgba(255, 255, 255, 0.95);
    padding: 12px;
    transform: translateY(110%);
    transition: transform 0.35s cubic-bezier(0, 0, 0.3, 1), opacity 0.35s ease;
    z-index: 5;
    opacity: 0;
    pointer-events: none;
    border-bottom-left-radius: {{ block.settings.card_border_radius }}px;
    border-bottom-right-radius: {{ block.settings.card_border_radius }}px;
  }

  .pgrid-card-{{ ai_gen_id }}:hover .pgrid-quickadd-{{ ai_gen_id }} {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .pgrid-quickadd-label-{{ ai_gen_id }} {
    display: none;
  }

  .pgrid-sizes-{{ ai_gen_id }} {
    display: flex;
    gap: 6px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .pgrid-size-btn-{{ ai_gen_id }} {
    background: #ffffff;
    color: #121212;
    border: 1px solid #e0e0e0;
    padding: 0;
    width: 44px;
    height: 44px;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.2s ease;
    border-radius: 0;
    font-weight: 500;
    text-align: center;
    letter-spacing: 0;
    font-family: inherit;
    line-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pgrid-size-btn-{{ ai_gen_id }}:hover {
    background: #121212;
    color: #ffffff;
    border-color: #121212;
  }

  .pgrid-size-btn-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
    text-decoration: line-through;
  }

  .pgrid-size-btn-{{ ai_gen_id }}.adding {
    background: #f0f0f0;
    color: #999;
    border-color: #e0e0e0;
    pointer-events: none;
  }

  .pgrid-size-btn-{{ ai_gen_id }}.added {
    background: #121212;
    color: #ffffff;
    border-color: #121212;
    pointer-events: none;
  }

  .pgrid-size-btn-{{ ai_gen_id }}.error {
    background: #ef4444;
    color: #ffffff;
    border-color: #ef4444;
    pointer-events: none;
  }

  /* ===== PRODUCT INFO ===== */
  .pgrid-info-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px 0;
    text-align: left !important;
  }

  .pgrid-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.product_title_color }};
    margin: 0 0 6px;
    font-weight: 500;
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    text-align: left !important;
  }

  .pgrid-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_price_size }}px;
    color: {{ block.settings.product_price_color }};
    font-weight: 600;
    letter-spacing: 0.5px;
    text-align: left !important;
  }

  .pgrid-price-compare-{{ ai_gen_id }} {
    text-decoration: line-through;
    opacity: 0.5;
    margin-left: 8px;
    font-weight: 400;
  }

  /* ===== SOLD OUT BADGE ===== */
  .pgrid-badge-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 2;
    padding: 5px 10px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    border-radius: 2px;
    line-height: 1;
  }

  .pgrid-badge-sold-{{ ai_gen_id }} {
    background: #000000;
    color: #ffffff;
  }

  .pgrid-badge-sale-{{ ai_gen_id }} {
    background: #ef4444;
    color: #ffffff;
  }

  /* ===== VIEW ALL BUTTON ===== */
  .pgrid-viewall-wrap-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    margin-top: {{ block.settings.button_spacing }}px;
  }

  /* Removed custom button styling to use theme-native .button styles */

  /* ===== EMPTY STATE ===== */
  .pgrid-empty-{{ ai_gen_id }} {
    grid-column: 1 / -1;
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.tab_text_color }};
    font-size: 14px;
    letter-spacing: 1px;
    border: 1px dashed {{ block.settings.tab_border_color }};
    border-radius: 8px;
  }

  .pgrid-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f0f0f0;
  }

  .pgrid-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.2;
  }

  /* ===== RESPONSIVE ===== */
  @media screen and (max-width: 989px) {
    .pgrid-{{ ai_gen_id }} {
      padding: 60px 0 0;
    }

    .pgrid-inner-{{ ai_gen_id }} {
      padding: 0 24px;
    }

    .pgrid-products-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }

    .pgrid-tab-{{ ai_gen_id }} {
      padding: 12px 20px;
      font-size: {{ block.settings.tab_font_size | minus: 2 }}px;
      letter-spacing: 1.5px;
    }
  }

  @media screen and (max-width: 749px) {
    .pgrid-{{ ai_gen_id }} {
      padding: 40px 0 0;
    }

    .pgrid-inner-{{ ai_gen_id }} {
      padding: 0 16px;
    }

    .pgrid-products-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }

    .pgrid-tabs-{{ ai_gen_id }} {
      gap: 0;
      overflow-x: auto;
      overflow-y: hidden;
      touch-action: pan-y;
      height: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      justify-content: flex-start;
      padding: 0 16px;
      margin-bottom: 30px;
    }

    .pgrid-tabs-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .pgrid-tab-{{ ai_gen_id }} {
      padding: 10px 16px;
      font-size: {{ block.settings.tab_font_size | minus: 3 }}px;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .pgrid-quickadd-{{ ai_gen_id }} {
      transform: translateY(0);
      position: relative;
      background: rgba(255, 255, 255, 0.95);
      padding: 10px;
    }

    .pgrid-size-btn-{{ ai_gen_id }} {
      width: 38px;
      height: 38px;
      font-size: 11px;
      line-height: 38px;
    }

    .pgrid-info-{{ ai_gen_id }} {
      padding: 10px;
    }

    .pgrid-title-{{ ai_gen_id }} {
      font-size: 12px;
    }

    .pgrid-price-{{ ai_gen_id }} {
      font-size: 12px;
    }



    .pgrid-viewall-{{ ai_gen_id }} {
      font-size: 12px;
      padding: 12px 28px;
    }
  }
{% endstyle %}

<product-grid-tabs-{{ ai_gen_id }} class="pgrid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="pgrid-inner-{{ ai_gen_id }}">

    <!-- Tab Navigation -->
    <div class="pgrid-tabs-{{ ai_gen_id }}" role="tablist">
      {% for i in (1..3) %}
        {% liquid
          assign title_key = 'tab_' | append: i | append: '_title'
          assign tab_title = block.settings[title_key]
        %}
        <button
          class="pgrid-tab-{{ ai_gen_id }}{% if i == 1 %} active{% endif %}"
          data-tab="{{ i }}"
          role="tab"
          aria-selected="{% if i == 1 %}true{% else %}false{% endif %}"
          aria-controls="pgrid-panel-{{ ai_gen_id }}-{{ i }}"
        >
          {{ tab_title }}
        </button>
      {% endfor %}
    </div>

    <!-- Tab Panels -->
    {% for i in (1..3) %}
      {% liquid
        assign collection_key = 'collection_' | append: i
        assign button_text_key = 'tab_' | append: i | append: '_button_text'
        assign button_url_key = 'tab_' | append: i | append: '_button_url'
        assign title_key = 'tab_' | append: i | append: '_title'
        
        assign collection = block.settings[collection_key]
        assign button_text = block.settings[button_text_key]
        assign button_url = block.settings[button_url_key]
        assign tab_title = block.settings[title_key]
      %}

      <div
        class="pgrid-panel-{{ ai_gen_id }}{% if i == 1 %} active{% endif %}"
        id="pgrid-panel-{{ ai_gen_id }}-{{ i }}"
        role="tabpanel"
      >
        <div class="pgrid-products-{{ ai_gen_id }}">
          {% if collection != blank and collection.products.size > 0 %}
            {% for product in collection.products limit: block.settings.products_to_show %}
              <div class="pgrid-card-{{ ai_gen_id }}" data-product-id="{{ product.id }}">

                {%- comment -%} Badges {%- endcomment -%}
                {% if product.available == false %}
                  <span class="pgrid-badge-{{ ai_gen_id }} pgrid-badge-sold-{{ ai_gen_id }}">Sold out</span>
                {% elsif product.compare_at_price > product.price %}
                  {% assign savings = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
                  <span class="pgrid-badge-{{ ai_gen_id }} pgrid-badge-sale-{{ ai_gen_id }}">-{{ savings }}%</span>
                {% endif %}

                <div class="pgrid-card-inner-{{ ai_gen_id }}" style="position: relative;">
                  <a href="{{ product.url }}" class="pgrid-card-link-{{ ai_gen_id }}">
                    <div class="pgrid-img-wrap-{{ ai_gen_id }}">
                      {% if product.featured_image %}
                        <img
                          class="pgrid-img-{{ ai_gen_id }}"
                          src="{{ product.featured_image | image_url: width: 600 }}"
                          alt="{{ product.featured_image.alt | escape }}"
                          loading="lazy"
                          width="600"
                          height="{{ 600 | divided_by: product.featured_image.aspect_ratio | round }}"
                        >
                        {% if product.images[1] %}
                          <img
                            class="pgrid-img-{{ ai_gen_id }} pgrid-img-secondary-{{ ai_gen_id }}"
                            src="{{ product.images[1] | image_url: width: 600 }}"
                            alt="{{ product.images[1].alt | escape }}"
                            loading="lazy"
                            width="600"
                            height="{{ 600 | divided_by: product.images[1].aspect_ratio | round }}"
                          >
                        {% endif %}
                      {% else %}
                        <div class="pgrid-placeholder-{{ ai_gen_id }}">
                          {{ 'product-1' | placeholder_svg_tag }}
                        </div>
                      {% endif %}
                    </div>
                  </a>

                  {%- comment -%} Quick-add overlay — moved outside image wrap for better stacking {%- endcomment -%}
                  {% if product.has_only_default_variant == false and product.available %}
                    <div class="pgrid-quickadd-{{ ai_gen_id }}">
                      <p class="pgrid-quickadd-label-{{ ai_gen_id }}">{{ block.settings.quick_add_title }}</p>
                      <div class="pgrid-sizes-{{ ai_gen_id }}">
                        {% for variant in product.variants %}
                          <button
                            class="pgrid-size-btn-{{ ai_gen_id }}"
                            data-variant-id="{{ variant.id }}"
                            {% unless variant.available %}disabled{% endunless %}
                            aria-label="Add {{ product.title }} — {{ variant.title }} to cart"
                          >
                            {{ variant.option1 }}
                          </button>
                        {% endfor %}
                      </div>
                    </div>
                  {% endif %}
                </div>

                <div class="pgrid-info-{{ ai_gen_id }}">
                  <h3 class="pgrid-title-{{ ai_gen_id }}">{{ product.title }}</h3>
                  <div class="pgrid-price-{{ ai_gen_id }}">
                    {{ product.price | money }}
                    {% if product.compare_at_price > product.price %}
                      <span class="pgrid-price-compare-{{ ai_gen_id }}">{{ product.compare_at_price | money }}</span>
                    {% endif %}
                  </div>
                </div>
              </div>
            {% endfor %}
          {% else %}
            <div class="pgrid-empty-{{ ai_gen_id }}">
              Select a collection for "{{ tab_title }}" in the theme editor
            </div>
          {% endif %}
        </div>

        {% if collection != blank and collection.products.size > 0 %}
          <div class="pgrid-viewall-wrap-{{ ai_gen_id }}">
            <a href="{{ button_url | default: collection.url }}" class="button button--secondary pgrid-viewall-{{ ai_gen_id }}">
              {{ button_text }}
              <span class="icon-wrap">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="width: 1.5rem; height: 1.5rem; margin-left: 1rem;">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </span>
            </a>
          </div>
        {% endif %}
      </div>
    {% endfor %}

  </div>
</product-grid-tabs-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductGridTabs{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        /* Grab the cart notification or cart drawer — whichever Dawn has active */
        this.cart = document.querySelector('cart-notification') || document.querySelector('cart-drawer');
      }

      connectedCallback() {
        this.initTabs();
        this.initQuickAdd();
      }

      /* ---------- TABS ---------- */
      initTabs() {
        const buttons = this.querySelectorAll('.pgrid-tab-{{ ai_gen_id }}');
        const panels  = this.querySelectorAll('.pgrid-panel-{{ ai_gen_id }}');

        buttons.forEach(btn => {
          btn.addEventListener('click', () => {
            const id = btn.dataset.tab;

            buttons.forEach(b => { b.classList.remove('active'); b.setAttribute('aria-selected', 'false'); });
            panels.forEach(p => p.classList.remove('active'));

            btn.classList.add('active');
            btn.setAttribute('aria-selected', 'true');

            const panel = this.querySelector(`#pgrid-panel-{{ ai_gen_id }}-${id}`);
            if (panel) panel.classList.add('active');
          });

          /* Keyboard: Arrow keys move between tabs */
          btn.addEventListener('keydown', (e) => {
            const btns = Array.from(buttons);
            const idx = btns.indexOf(e.target);
            let next;
            if (e.key === 'ArrowRight') { e.preventDefault(); next = btns[(idx + 1) % btns.length]; }
            if (e.key === 'ArrowLeft')  { e.preventDefault(); next = btns[(idx - 1 + btns.length) % btns.length]; }
            if (next) { next.click(); next.focus(); }
          });
        });
      }

      /* ---------- QUICK ADD TO CART ---------- */
      initQuickAdd() {
        this.querySelectorAll('.pgrid-size-btn-{{ ai_gen_id }}').forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            this.addToCart(btn);
          });
        });
      }

      async addToCart(button) {
        if (button.disabled || button.classList.contains('adding')) return;

        const variantId = button.getAttribute('data-variant-id');
        const originalText = button.textContent;

        button.classList.add('adding');
        button.textContent = '•••';

        try {
          /* Use FormData just like product-form.js does */
          const formData = new FormData();
          formData.append('id', variantId);
          formData.append('quantity', '1');

          if (this.cart) {
            formData.append(
              'sections',
              this.cart.getSectionsToRender().map((section) => section.id)
            );
            formData.append('sections_url', window.location.pathname);
            this.cart.setActiveElement(document.activeElement);
          }

          const config = typeof fetchConfig === 'function' ? fetchConfig('javascript') : {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
          };
          config.headers['X-Requested-With'] = 'XMLHttpRequest';
          delete config.headers['Content-Type'];
          config.body = formData;

          const res = await fetch(window.routes?.cart_add_url || '/cart/add.js', config);
          const response = await res.json();

          /* Check for error — Dawn returns { status: 422, ... } on failure */
          if (response.status) {
            throw new Error(response.description || 'Could not add to cart');
          }

          /* Success feedback on button */
          button.classList.remove('adding');
          button.classList.add('added');
          button.textContent = '✓';

          /* Publish cartUpdate FIRST (same order as product-form.js) */
          if (typeof publish === 'function' && typeof PUB_SUB_EVENTS !== 'undefined') {
            publish(PUB_SUB_EVENTS.cartUpdate, {
              source: 'product-grid-tabs',
              productVariantId: variantId,
              cartData: response
            });
          }

          /* Then tell Dawn to update the cart icon count + open the notification / drawer */
          if (this.cart) {
            this.cart.renderContents(response);
          }

          /* Remove is-empty class if the cart was empty */
          if (this.cart && this.cart.classList.contains('is-empty')) {
            this.cart.classList.remove('is-empty');
          }

          setTimeout(() => {
            button.textContent = originalText;
            button.classList.remove('added');
          }, 1800);

        } catch (err) {
          console.error('Quick add error:', err);
          button.classList.remove('adding');
          button.classList.add('error');
          button.textContent = '✗';

          setTimeout(() => {
            button.textContent = originalText;
            button.classList.remove('error');
          }, 1800);
        }
      }
    }

    customElements.define('product-grid-tabs-{{ ai_gen_id }}', ProductGridTabs{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Product grid with tabs",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Tab 1"
    },
    {
      "type": "text",
      "id": "tab_1_title",
      "label": "Title",
      "default": "REGULAR FIT"
    },
    {
      "type": "collection",
      "id": "collection_1",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "tab_1_button_text",
      "label": "Button text",
      "default": "View all"
    },
    {
      "type": "url",
      "id": "tab_1_button_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Tab 2"
    },
    {
      "type": "text",
      "id": "tab_2_title",
      "label": "Title",
      "default": "OVERSIZED FIT"
    },
    {
      "type": "collection",
      "id": "collection_2",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "tab_2_button_text",
      "label": "Button text",
      "default": "View all"
    },
    {
      "type": "url",
      "id": "tab_2_button_url",
      "label": "Button URL"
    },
    {
