{% doc %}
  @prompt
    Create a premium Shopify theme section called "Cinematic Product Feature" designed for high-end product storytelling on a fitness apparel brand homepage.
    
    Purpose:
    Showcase a single product using immersive background media with cinematic presentation, strong typography, and a clear call-to-action.
    
    Section Structure:
    The section should support a full-width background media container that can be either:
    • Image
    • Video
    
    Media Requirements:
    • Image or video fills entire section container
    • Video should autoplay, muted, loop, and be optimized for web performance
    • Add optional dark gradient overlay to ensure text readability
    • Support subtle parallax scrolling effect on desktop
    
    Overlay Content:
    Overlay a content container above the media containing:
    • Heading
    • Short description text
    • Primary CTA button
    
    Content Position Controls:
    Allow selecting where the overlay content appears on desktop:
    • Left Center
    • Right Center
    • Bottom Left
    • Bottom Right
    • Center
    
    Mobile Layout:
    Mobile layout should automatically adapt to a near full-screen cinematic experience.
    
    Mobile controls should allow separate positioning:
    • Bottom Center
    • Bottom Left
    • Bottom Right
    • Center
    • Top Right
    
    Height Controls:
    Allow selecting section height with options:
    • Small (500px)
    • Medium (650px)
    • Large (800px)
    • Full Screen (100vh)
    • Custom Height
    
    If Custom Height is selected, allow entering a manual height value (px, vh, or rem).
    
    Reusable Content Settings:
    Each instance of the section should allow editing:
    • Heading text
    • Description text
    • Button label
    • Button link
    • Text alignment
    • Text color
    • Overlay opacity
    
    Theme Integration:
    The section must inherit styles from the active Shopify theme:
    • Typography
    • Button styles
    • Color variables
    • Spacing system
    
    Visual Enhancements:
    • Add subtle fade-in animation for text when the section enters the viewport
    • Ensure text container has responsive padding
    • Prevent text from touching screen edges on smaller devices
    
    Performance:
    • Lazy-load images
    • Optimize video loading
    • Ensure the section does not negatively impact page load speed
    
    Reusability:
    The section should be reusable multiple times on the homepage to showcase different products with different media and content positions.
    
    Ensure the section schema exposes all customization options in the Shopify theme editor.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  assign height_value = block.settings.section_height
  if height_value == 'custom'
    assign custom_height = block.settings.custom_height
  endif
%}

{% style %}
  .ai-cinematic-feature-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    overflow: hidden;
    {% if height_value == 'small' %}
      height: 500px;
    {% elsif height_value == 'medium' %}
      height: 650px;
    {% elsif height_value == 'large' %}
      height: 800px;
    {% elsif height_value == 'fullscreen' %}
      height: 100vh;
    {% elsif height_value == 'custom' %}
      height: {{ custom_height }};
    {% endif %}
  }

  .ai-cinematic-feature__media-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-cinematic-feature__media-inner-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .ai-cinematic-feature__image-{{ ai_gen_id }},
  .ai-cinematic-feature__video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (min-width: 750px) {
    .ai-cinematic-feature__media-inner-{{ ai_gen_id }}.parallax-enabled {
      transform: translateY(var(--parallax-offset, 0));
      transition: transform 0.1s linear;
    }
  }

  .ai-cinematic-feature__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-cinematic-feature__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 600px;
    max-height: 600px;
    opacity: 0.3;
  }

  .ai-cinematic-feature__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    padding: 16px 24px;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.7);
    text-align: center;
    pointer-events: none;
    background: rgba(0, 0, 0, 0.5);
    border-radius: 4px;
  }

  .ai-cinematic-feature__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, {{ block.settings.overlay_opacity }}%) 100%);
    z-index: 2;
    pointer-events: none;
  }

  .ai-cinematic-feature__content-wrapper-{{ ai_gen_id }} {
    position: absolute;
    z-index: 3;
    width: 100%;
    height: 100%;
    display: flex;
    padding: 40px;
    {% if block.settings.desktop_position == 'left-center' %}
      align-items: center;
      justify-content: flex-start;
    {% elsif block.settings.desktop_position == 'right-center' %}
      align-items: center;
      justify-content: flex-end;
    {% elsif block.settings.desktop_position == 'bottom-left' %}
      align-items: flex-end;
      justify-content: flex-start;
    {% elsif block.settings.desktop_position == 'bottom-right' %}
      align-items: flex-end;
      justify-content: flex-end;
    {% elsif block.settings.desktop_position == 'center' %}
      align-items: center;
      justify-content: center;
    {% endif %}
  }

  @media (max-width: 749px) {
    .ai-cinematic-feature__content-wrapper-{{ ai_gen_id }} {
      padding: 24px;
      {% if block.settings.mobile_position == 'bottom-center' %}
        align-items: flex-end;
        justify-content: center;
      {% elsif block.settings.mobile_position == 'bottom-left' %}
        align-items: flex-end;
        justify-content: flex-start;
      {% elsif block.settings.mobile_position == 'bottom-right' %}
        align-items: flex-end;
        justify-content: flex-end;
      {% elsif block.settings.mobile_position == 'center' %}
        align-items: center;
        justify-content: center;
      {% elsif block.settings.mobile_position == 'top-right' %}
        align-items: flex-start;
        justify-content: flex-end;
      {% endif %}
    }

    .ai-cinematic-feature-{{ ai_gen_id }} {
      min-height: 90vh;
    }
  }

  .ai-cinematic-feature__content-{{ ai_gen_id }} {
    max-width: 600px;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .ai-cinematic-feature-{{ ai_gen_id }}.in-view .ai-cinematic-feature__content-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateY(0);
  }

  .ai-cinematic-feature__heading-{{ ai_gen_id }} {
    font-size: 48px;
    font-weight: 700;
    line-height: 1.1;
    margin: 0 0 16px;
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  @media (max-width: 749px) {
    .ai-cinematic-feature__heading-{{ ai_gen_id }} {
      font-size: 32px;
    }
  }

  .ai-cinematic-feature__description-{{ ai_gen_id }} {
    font-size: 18px;
    line-height: 1.6;
    margin: 0 0 24px;
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  @media (max-width: 749px) {
    .ai-cinematic-feature__description-{{ ai_gen_id }} {
      font-size: 16px;
    }
  }

  .ai-cinematic-feature__button-wrapper-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-cinematic-feature__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 16px 32px;
    background-color: #ffffff;
    color: #121212;
    text-decoration: none;
    font-weight: 600;
    font-size: 16px;
    border-radius: {{ settings.buttons_radius }}px;
    transition: all 0.3s ease;
    border: {{ settings.buttons_border_thickness }}px solid rgba(0, 0, 0, {{ settings.buttons_border_opacity | divided_by: 100.0 }});
  }

  .ai-cinematic-feature__button-{{ ai_gen_id }}:hover {
    background-color: #121212;
    color: #ffffff;
    transform: translateY(-2px);
  }
{% endstyle %}

<cinematic-product-feature-{{ ai_gen_id }}
  class="ai-cinematic-feature-{{ ai_gen_id }}"
  data-parallax="{{ block.settings.enable_parallax }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-cinematic-feature__media-{{ ai_gen_id }}">
    <div class="ai-cinematic-feature__media-inner-{{ ai_gen_id }} {% if block.settings.enable_parallax %}parallax-enabled{% endif %}">
      {% if block.settings.video_url != blank %}
        <video
          class="ai-cinematic-feature__video-{{ ai_gen_id }}"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
        >
          <source src="{{ block.settings.video_url }}" type="video/mp4">
        </video>
      {% elsif block.settings.background_image %}
        <img
          src="{{ block.settings.background_image | image_url: width: 2000 }}"
          srcset="{{ block.settings.background_image | image_url: width: 750 }} 750w,
                  {{ block.settings.background_image | image_url: width: 1500 }} 1500w,
                  {{ block.settings.background_image | image_url: width: 2000 }} 2000w"
          sizes="100vw"
          alt="{{ block.settings.background_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.background_image.width }}"
          height="{{ block.settings.background_image.height }}"
          class="ai-cinematic-feature__image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-cinematic-feature__placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-cinematic-feature__empty-state-{{ ai_gen_id }}">
            Add a background image or video to get started
          </div>
        </div>
      {% endif %}
    </div>
  </div>

  {% if block.settings.enable_overlay %}
    <div class="ai-cinematic-feature__overlay-{{ ai_gen_id }}"></div>
  {% endif %}

  <div class="ai-cinematic-feature__content-wrapper-{{ ai_gen_id }}">
    <div class="ai-cinematic-feature__content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-cinematic-feature__heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      {% endif %}

      {% if block.settings.description != blank %}
        <div class="ai-cinematic-feature__description-{{ ai_gen_id }}">
          {{ block.settings.description }}
        </div>
      {% endif %}

      {% if block.settings.button_label != blank and block.settings.button_link != blank %}
        <div class="ai-cinematic-feature__button-wrapper-{{ ai_gen_id }}">
          <a
            href="{{ block.settings.button_link }}"
            class="ai-cinematic-feature__button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_label }}
          </a>
        </div>
      {% endif %}
    </div>
  </div>
</cinematic-product-feature-{{ ai_gen_id }}>

<script>
  (function() {
    class CinematicProductFeature{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.parallaxEnabled = this.dataset.parallax === 'true';
        this.mediaInner = this.querySelector('.ai-cinematic-feature__media-inner-{{ ai_gen_id }}');
      }

      connectedCallback() {
        this.setupIntersectionObserver();
        if (this.parallaxEnabled && window.innerWidth >= 750) {
          this.setupParallax();
        }
      }

      setupIntersectionObserver() {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              this.classList.add('in-view');
            }
          });
        }, {
          threshold: 0.2
        });

        observer.observe(this);
      }

      setupParallax() {
        let ticking = false;

        const updateParallax = () => {
          const rect = this.getBoundingClientRect();
          const scrollPercent = (window.innerHeight - rect.top) / (window.innerHeight + rect.height);
          const parallaxOffset = (scrollPercent - 0.5) * 100;

          if (this.mediaInner) {
            this.mediaInner.style.setProperty('--parallax-offset', `${parallaxOffset}px`);
          }

          ticking = false;
        };

        const requestTick = () => {
          if (!ticking) {
            window.requestAnimationFrame(updateParallax);
            ticking = true;
          }
        };

        window.addEventListener('scroll', requestTick, { passive: true });
        updateParallax();
      }
    }

    customElements.define('cinematic-product-feature-{{ ai_gen_id }}', CinematicProductFeature{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Cinematic product feature",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL",
      "info": "MP4 format recommended. Video will override image if both are set."
    },
    {
      "type": "checkbox",
      "id": "enable_overlay",
      "label": "Enable gradient overlay",
      "default": true
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 40
    },
    {
      "type": "checkbox",
      "id": "enable_parallax",
      "label": "Enable parallax effect",
      "default": true,
      "info": "Desktop only"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Elevate Your Performance"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Discover premium athletic wear designed for champions. Engineered for performance, crafted for style.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Section height",
      "options": [
        {
          "value": "small",
          "label": "Small (500px)"
        },
        {
          "value": "medium",
          "label": "Medium (650px)"
        },
        {
          "value": "large",
          "label": "Large (800px)"
        },
        {
          "value": "fullscreen",
          "label": "Full screen (100vh)"
        },
        {
          "value": "custom",
          "label": "Custom height"
        }
      ],
      "default": "large"
    },
    {
      "type": "text",
      "id": "custom_height",
      "label": "Custom height",
      "default": "700px",
      "info": "Only applies when 'Custom height' is selected. Use px, vh, or rem units."
    },
    {
      "type": "select",
      "id": "desktop_position",
      "label": "Content position (desktop)",
      "options": [
        {
          "value": "left-center",
          "label": "Left center"
        },
        {
          "value": "right-center",
          "label": "Right center"
        },
        {
          "value": "bottom-left",
          "label": "Bottom left"
        },
        {
          "value": "bottom-right",
          "label": "Bottom right"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "left-center"
    },
    {
      "type": "select",
      "id": "mobile_position",
      "label": "Content position (mobile)",
      "options": [
        {
          "value": "bottom-center",
          "label": "Bottom center"
        },
        {
          "value": "bottom-left",
