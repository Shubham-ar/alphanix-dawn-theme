{% assign section_id = section.id | replace: '_', '' | downcase %}

{% liquid
  assign total_step_duration = 0
  for block in section.blocks
    assign total_step_duration = total_step_duration | plus: block.settings.scroll_duration
  endfor
%}

<section id="scroll-story-{{ section_id }}" class="scroll-story" style="--total-height: {{ total_step_duration }}vh">

  <div class="story-media">
    {% if section.settings.image != blank %}
      <img
        src="{{ section.settings.image | image_url: width: 2000 }}"
        class="story-image"
        loading="lazy"
        width="2000"
        height="{{ 2000 | divided_by: section.settings.image.aspect_ratio | round }}"
      >
    {% else %}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'story-image placeholder' }}
    {% endif %}
    
    <div class="story-overlay-{{ section_id }}"></div>

    <div class="story-content">
      {% for block in section.blocks %}
        {% assign block_id = block.id | replace: '_', '' | downcase %}
        <div 
          class="story-step step-{{ forloop.index0 }} pos-{{ block.settings.vertical_alignment }}-{{ block.settings.horizontal_alignment }} mobile-pos-{{ block.settings.mobile_vertical_alignment }}-{{ block.settings.mobile_horizontal_alignment }}" 
          data-index="{{ forloop.index0 }}"
          data-duration="{{ block.settings.scroll_duration }}"
          {{ block.shopify_attributes }}
        >
          <div class="step-inner step-inner-{{ block_id }}">
            {% if block.settings.heading != blank %}
              <h2 class="step-heading-{{ block_id }} {{ block.settings.heading_size }} mobile-{{ block.settings.mobile_heading_size }}">{{ block.settings.heading }}</h2>
            {% endif %}

            {% if block.settings.description != blank %}
              <div class="step-description-{{ block_id }} {{ block.settings.description_style }}">
                {{ block.settings.description }}
              </div>
            {% endif %}

            {% if block.settings.button_label != blank or block.settings.button_label_2 != blank %}
              <div class="step-buttons">
                {% if block.settings.button_label != blank %}
                  <a href="{{ block.settings.button_link }}" class="button {% if block.settings.button_style_secondary %}button--secondary{% else %}button--primary{% endif %}">
                    {{ block.settings.button_label }}
                  </a>
                {% endif %}
                
                {% if block.settings.button_label_2 != blank %}
                  <a href="{{ block.settings.button_link_2 }}" class="button {% if block.settings.button_style_secondary_2 %}button--secondary{% else %}button--primary{% endif %}">
                    {{ block.settings.button_label_2 }}
                  </a>
                {% endif %}
              </div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>

</section>

{% style %}

#scroll-story-{{ section_id }} {
  position: relative;
  height: var(--total-height);
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
}

.story-media {
  position: sticky;
  top: 0;
  height: {{ section.settings.desktop_height }}vh;
  overflow: hidden;
  z-index: 1;
}

@media screen and (max-width: 749px) {
  .story-media {
    height: {{ section.settings.mobile_height }}vh;
  }
}

.story-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transform: scale(1);
  will-change: transform;
}

.story-overlay-{{ section_id }} {
  position: absolute;
  inset: 0;
  {% if section.settings.enable_overlay_gradient %}
    background: linear-gradient(
      {{ section.settings.gradient_direction }},
      {{ section.settings.gradient_color_1 }} 0%,
      {{ section.settings.gradient_color_2 }} 100%
    );
  {% else %}
    background-color: {{ section.settings.overlay_color }};
  {% endif %}
  opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
}

.story-content {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 5;
}

.story-step {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  opacity: 0;
  visibility: hidden;
  transform: translateY(20px);
  transition: opacity 0.6s ease, transform 0.6s ease, visibility 0.6s;
  padding: 40px;
}

.story-step.active {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
  pointer-events: auto;
}

/* Desktop position classes */
.pos-top-left { align-items: flex-start; justify-content: flex-start; }
.pos-top-center { align-items: flex-start; justify-content: center; }
.pos-top-right { align-items: flex-start; justify-content: flex-end; }
.pos-center-left { align-items: center; justify-content: flex-start; }
.pos-center-center { align-items: center; justify-content: center; }
.pos-center-right { align-items: center; justify-content: flex-end; }
.pos-bottom-left { align-items: flex-end; justify-content: flex-start; }
.pos-bottom-center { align-items: flex-end; justify-content: center; }
.pos-bottom-right { align-items: flex-end; justify-content: flex-end; }

/* Mobile position classes */
@media screen and (max-width: 749px) {
  .mobile-pos-top-left { align-items: flex-start; justify-content: flex-start; }
  .mobile-pos-top-center { align-items: flex-start; justify-content: center; }
  .mobile-pos-top-right { align-items: flex-start; justify-content: flex-end; }
  .mobile-pos-center-left { align-items: center; justify-content: flex-start; }
  .mobile-pos-center-center { align-items: center; justify-content: center; }
  .mobile-pos-center-right { align-items: center; justify-content: flex-end; }
  .mobile-pos-bottom-left { align-items: flex-end; justify-content: flex-start; }
  .mobile-pos-bottom-center { align-items: flex-end; justify-content: center; }
  .mobile-pos-bottom-right { align-items: flex-end; justify-content: flex-end; }
  .story-step { padding: 20px; }
}

{% for block in section.blocks %}
  {% assign block_id = block.id | replace: '_', '' | downcase %}
  
  .step-inner-{{ block_id }} {
    text-align: {{ block.settings.text_alignment }};
    max-width: {{ block.settings.content_max_width }}px;
  }

  .step-heading-{{ block_id }} {
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.1;
    {% if block.settings.heading_uppercase %}
      text-transform: uppercase;
    {% endif %}
    {% if block.settings.enable_text_shadow %}
      text-shadow: 0 2px 4px rgba(0,0,0,0.5);
    {% endif %}
  }

  .step-description-{{ block_id }} {
    color: {{ block.settings.text_color }};
    margin-top: 15px;
    {% if block.settings.description_uppercase %}
      text-transform: uppercase;
    {% endif %}
    {% if block.settings.enable_text_shadow %}
      text-shadow: 0 1px 3px rgba(0,0,0,0.3);
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .step-inner-{{ block_id }} {
      text-align: {{ block.settings.mobile_text_alignment }};
      max-width: {{ block.settings.mobile_content_max_width }}px;
    }
  }

  .step-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
    justify-content: {% if block.settings.text_alignment == 'center' %}center{% elsif block.settings.text_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
    margin-top: 24px;
    pointer-events: auto;
  }

  @media screen and (max-width: 749px) {
    .step-buttons {
      justify-content: {% if block.settings.mobile_text_alignment == 'center' %}center{% elsif block.settings.mobile_text_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
    }
  }
{% endfor %}

{% endstyle %}

<script>
{
  const sectionId = "{{ section_id }}";
  const section = document.querySelector('#scroll-story-' + sectionId);
  if (section) {
    const image = section.querySelector('.story-image');
    const steps = section.querySelectorAll('.story-step');
    const zoomIntensity = {{ section.settings.zoom_intensity | divided_by: 100.0 | default: 0.3 }};
    const persistLast = {{ section.settings.persist_last_step | default: true }};
    
    let ticking = false;
    let isVisible = false;

    // Precalculate step timing based on durations
    const stepDurations = Array.from(steps).map(s => parseFloat(s.dataset.duration));
    const totalDuration = stepDurations.reduce((a, b) => a + b, 0);
    
    const stepThresholds = [];
    let cumulative = 0;
    stepDurations.forEach(d => {
      const start = cumulative / totalDuration;
      cumulative += d;
      const end = cumulative / totalDuration;
      stepThresholds.push({ start, end });
    });

    const updateStory = () => {
      if (!isVisible) return;
      
      const rect = section.getBoundingClientRect();
      const scrollEnd = rect.height - window.innerHeight;
      
      let progress = -rect.top / scrollEnd;
      progress = Math.min(Math.max(progress, 0), 1);

      const zoom = 1 + progress * zoomIntensity;
      if (image) image.style.transform = `scale(${zoom})`;

      const stepCount = steps.length;
      
      steps.forEach((step, i) => {
        const { start, end } = stepThresholds[i];

        if (i === stepCount - 1 && persistLast) {
          if (progress >= start) {
             step.classList.add('active');
          } else {
             step.classList.remove('active');
          }
        } 
        else {
          if (progress >= start && progress < end) {
             step.classList.add('active');
          } else {
             step.classList.remove('active');
          }
        }
      });

      ticking = false;
    };

    const onScroll = () => {
      if (!ticking) {
        requestAnimationFrame(updateStory);
        ticking = true;
      }
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        isVisible = entry.isIntersecting;
        if (isVisible) {
          window.addEventListener('scroll', onScroll, { passive: true });
          updateStory();
        } else {
          window.removeEventListener('scroll', onScroll);
        }
      });
    }, { threshold: 0, rootMargin: '0px' });

    observer.observe(section);
    window.addEventListener('resize', () => {
      if (isVisible) updateStory();
    });
  }
}
</script>

{% schema %}
{
  "name": "Scroll Story Product",
  "settings": [
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
