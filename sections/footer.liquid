{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

{%- style -%}
  /* =============================================
     ALPHANIX FOOTER
     All selectors prefixed with #shopify-section-ID
     so they beat Dawn's base styles every time.
     ============================================= */

  #shopify-section-{{ section.id }} .alphanix-footer {
    background-color: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    border-top: 1px solid rgba(var(--color-foreground), 0.1);
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    margin-top: {{ section.settings.margin_top }}px;
  }

  /* ---- Top grid ---- */
  #shopify-section-{{ section.id }} .alphanix-footer__top {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1.6fr;
    gap: 48px 40px;
    padding: 0 var(--page-width-padding, 40px);
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
  }

  /* ---- Brand column ---- */
  #shopify-section-{{ section.id }} .alphanix-footer__brand-name {
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin: 0 0 12px;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .alphanix-footer__brand-desc {
    line-height: 1.65;
    opacity: 0.7;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .alphanix-footer__social {
    margin-top: 20px;
  }

  /* ---- Link columns ---- */
  #shopify-section-{{ section.id }} .alphanix-footer__col-heading {
    font-weight: 700;
    letter-spacing: 0.02em;
    margin: 0 0 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: default;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .alphanix-footer__col-heading .alphanix-footer__chevron {
    display: none;
    width: 20px;
    height: 20px;
    transition: transform 0.25s ease;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .alphanix-footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  #shopify-section-{{ section.id }} .alphanix-footer__links a,
  #shopify-section-{{ section.id }} .alphanix-footer__links li a {
    color: rgb(var(--color-foreground));
    text-decoration: none;
    opacity: 0.7;
    transition: opacity 0.2s ease;
    display: inline-block;
  }

  #shopify-section-{{ section.id }} .alphanix-footer__links a:hover,
  #shopify-section-{{ section.id }} .alphanix-footer__links li a:hover {
    opacity: 1;
  }

  /* ---- Newsletter column ---- */
  #shopify-section-{{ section.id }} .alphanix-footer__newsletter-heading {
    font-weight: 700;
    margin: 0 0 10px;
    line-height: 1.3;
  }

  #shopify-section-{{ section.id }} .alphanix-footer__newsletter-sub {
    opacity: 0.7;
    margin: 0 0 18px;
    line-height: 1.55;
  }

  #shopify-section-{{ section.id }} .alphanix-footer__newsletter-sub p {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .alphanix-footer__newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  #shopify-section-{{ section.id }} .alphanix-footer__email-wrapper {
    position: relative;
  }

  #shopify-section-{{ section.id }} .alphanix-footer__email-input {
    width: 100%;
    padding: 13px 16px;
    border: 1px solid rgba(var(--color-foreground), 0.25);
    border-radius: 4px;
    background: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    box-sizing: border-box;
    outline: none;
    transition: border-color 0.2s ease;
    -webkit-appearance: none;
    height: auto;
  }

  #shopify-section-{{ section.id }} .alphanix-footer__email-input::placeholder {
    color: rgba(var(--color-foreground), 0.4);
  }

  #shopify-section-{{ section.id }} .alphanix-footer__email-input:focus {
    border-color: rgba(var(--color-foreground), 0.65);
  }

  #shopify-section-{{ section.id }} .alphanix-footer__subscribe-btn {
    width: 100%;
    padding: 14px 16px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: none;
    border-radius: 4px;
    background: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
    cursor: pointer;
    transition: opacity 0.2s ease;
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .alphanix-footer__subscribe-btn:hover {
    opacity: 0.8;
  }

  #shopify-section-{{ section.id }} .alphanix-footer__form-message {
    margin-top: 6px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  #shopify-section-{{ section.id }} .alphanix-footer__form-message--error {
    color: rgb(var(--color-error, 176 0 0));
  }

  #shopify-section-{{ section.id }} .alphanix-footer__form-message--success {
    color: rgb(var(--color-foreground));
    opacity: 0.8;
  }

  /* ---- Bottom bar ---- */
  #shopify-section-{{ section.id }} .alphanix-footer__bottom {
    margin-top: 48px;
    padding: 20px var(--page-width-padding, 40px) 0;
    max-width: var(--page-width, 1200px);
    margin-left: auto;
    margin-right: auto;
    border-top: 1px solid rgba(var(--color-foreground), 0.1);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }

  #shopify-section-{{ section.id }} .alphanix-footer__copyright {
    opacity: 0.5;
  }

  #shopify-section-{{ section.id }} .alphanix-footer__bottom-right {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  #shopify-section-{{ section.id }} .alphanix-footer__policies {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  #shopify-section-{{ section.id }} .alphanix-footer__policies a {
    color: rgb(var(--color-foreground));
    opacity: 0.5;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  #shopify-section-{{ section.id }} .alphanix-footer__policies a:hover {
    opacity: 1;
  }

  #shopify-section-{{ section.id }} .footer__payment {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  #shopify-section-{{ section.id }} .footer__payment .list-payment {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* ---- Localization ---- */
  #shopify-section-{{ section.id }} .alphanix-footer__localization {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 24px var(--page-width-padding, 40px) 0;
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  /* =============================================
     TABLET  (max 900px → 2-col)
     ============================================= */
  @media screen and (max-width: 899px) {
    #shopify-section-{{ section.id }} .alphanix-footer__top {
      grid-template-columns: 1fr 1fr;
      gap: 36px 32px;
    }
  }

  /* =============================================
     MOBILE  (max 599px → single col + accordions)
     ============================================= */
  @media screen and (max-width: 599px) {
    #shopify-section-{{ section.id }} .alphanix-footer {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    #shopify-section-{{ section.id }} .alphanix-footer__top {
      grid-template-columns: 1fr;
      gap: 0;
      padding: 0 20px;
    }

    /* Brand — always visible, divider below */
    #shopify-section-{{ section.id }} .alphanix-footer__col--brand {
      padding-bottom: 28px;
      border-bottom: 1px solid rgba(var(--color-foreground), 0.1);
    }

    /* Newsletter — always visible, pushed after link cols */
    #shopify-section-{{ section.id }} .alphanix-footer__col--newsletter {
      padding-top: 28px;
      order: 99;
    }

    /* Link columns → accordion */
    #shopify-section-{{ section.id }} .alphanix-footer__col--links {
      border-bottom: 1px solid rgba(var(--color-foreground), 0.1);
    }

    #shopify-section-{{ section.id }} .alphanix-footer__col--links .alphanix-footer__col-heading {
      cursor: pointer;
      padding: 18px 0;
      margin: 0;
      user-select: none;
    }

    #shopify-section-{{ section.id }} .alphanix-footer__col--links .alphanix-footer__chevron {
      display: block;
    }

    /* Collapsed state */
    #shopify-section-{{ section.id }} .alphanix-footer__col--links .alphanix-footer__links {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.32s ease, padding-bottom 0.32s ease;
      padding-bottom: 0;
    }

    /* Expanded state */
    #shopify-section-{{ section.id }} .alphanix-footer__col--links.is-open .alphanix-footer__links {
      max-height: 800px;
      padding-bottom: 18px;
    }

    #shopify-section-{{ section.id }} .alphanix-footer__col--links.is-open .alphanix-footer__chevron {
      transform: rotate(180deg);
    }

    #shopify-section-{{ section.id }} .alphanix-footer__bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
      padding: 20px 20px 0;
      margin-top: 32px;
    }

    #shopify-section-{{ section.id }} .alphanix-footer__localization {
      padding: 20px 20px 0;
    }
  }
{%- endstyle -%}

{%- liquid
  assign has_social_icons = true
  if settings.social_facebook_link == blank and settings.social_instagram_link == blank and settings.social_youtube_link == blank and settings.social_tiktok_link == blank and settings.social_twitter_link == blank and settings.social_pinterest_link == blank and settings.social_snapchat_link == blank and settings.social_tumblr_link == blank and settings.social_vimeo_link == blank
    assign has_social_icons = false
  endif
-%}

<footer class="alphanix-footer color-{{ section.settings.color_scheme }} gradient">

  <div class="alphanix-footer__top">

    {%- for block in section.blocks -%}
      {%- case block.type -%}

        {%- when '@app' -%}
          <div class="alphanix-footer__col" {{ block.shopify_attributes }}>
            {% render block %}
          </div>

        {%- when 'brand_information' -%}
          <div class="alphanix-footer__col alphanix-footer__col--brand" {{ block.shopify_attributes }}>
            {%- if settings.brand_image != blank -%}
              {%- assign brand_image_height = settings.brand_image_width | divided_by: settings.brand_image.aspect_ratio -%}
              <div style="max-width: min(100%, {{ settings.brand_image_width }}px); margin-bottom: 14px;">
                {{
                  settings.brand_image
                  | image_url: width: 1100
                  | image_tag:
                    loading: 'lazy',
                    widths: '50, 100, 150, 200, 300, 400, 550',
                    height: brand_image_height,
                    width: settings.brand_image_width
                }}
              </div>
            {%- endif -%}
            {%- if settings.brand_headline != blank -%}
              <h2 class="alphanix-footer__brand-name h3">{{ settings.brand_headline }}</h2>
            {%- else -%}
              <h2 class="alphanix-footer__brand-name h3">ALPHANIX</h2>
            {%- endif -%}
            {%- if settings.brand_description != blank -%}
              <p class="alphanix-footer__brand-desc">{{ settings.brand_description }}</p>
            {%- endif -%}
            {%- if block.settings.show_social and has_social_icons -%}
              <div class="alphanix-footer__social">
                {%- render 'social-icons', class: 'footer__list-social' -%}
              </div>
            {%- endif -%}
          </div>

        {%- when 'text' -%}
          <div
            class="alphanix-footer__col alphanix-footer__col--links{% if block.settings.default_open %} is-open{% endif %}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.heading != blank -%}
              <h2 class="alphanix-footer__col-heading h5">
                {{- block.settings.heading -}}
                <svg class="alphanix-footer__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </h2>
            {%- endif -%}
            <div class="alphanix-footer__links rte">
              {{ block.settings.subtext }}
            </div>
            {%- if block.settings.show_social and has_social_icons -%}
              <div class="alphanix-footer__social" style="margin-top: 16px;">
                {%- render 'social-icons', class: 'footer__list-social' -%}
              </div>
            {%- endif -%}
          </div>

        {%- when 'link_list' -%}
          {%- if block.settings.menu != blank -%}
            <div
              class="alphanix-footer__col alphanix-footer__col--links{% if block.settings.default_open %} is-open{% endif %}"
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.heading != blank -%}
                <h2 class="alphanix-footer__col-heading h5">
                  {{- block.settings.heading -}}
                  <svg class="alphanix-footer__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="6 9 12 15 18 9"></polyline>
                  </svg>
                </h2>
              {%- endif -%}
              <ul class="alphanix-footer__links">
                {%- for link in block.settings.menu.links -%}
                  <li>
                    <a href="{{ link.url }}"{% if link.active %} aria-current="page"{% endif %}>
                      {{ link.title | escape }}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}

        {%- when 'newsletter' -%}
          <div class="alphanix-footer__col alphanix-footer__col--newsletter" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h2 class="alphanix-footer__newsletter-heading h4">{{- block.settings.heading -}}</h2>
            {%- endif -%}
            {%- if block.settings.subtext != blank -%}
              <div class="alphanix-footer__newsletter-sub">{{ block.settings.subtext }}</div>
            {%- endif -%}
            {%- form 'customer', id: 'ContactFooter', class: 'alphanix-footer__newsletter-form' -%}
              <input type="hidden" name="contact[tags]" value="newsletter">
              <div class="alphanix-footer__email-wrapper">
                <input
                  id="NewsletterForm--{{ section.id }}"
                  type="email"
                  name="contact[email]"
                  class="alphanix-footer__email-input"
                  value="{{ form.email }}"
                  aria-required="true"
                  autocorrect="off"
                  autocapitalize="off"
                  autocomplete="email"
                  {% if form.errors %}
                    autofocus
                    aria-invalid="true"
                    aria-describedby="ContactFooter-error"
                  {% elsif form.posted_successfully? %}
                    aria-describedby="ContactFooter-success"
                  {% endif %}
                  placeholder="Enter your email"
                  required
                >
              </div>
              <button
                type="submit"
                class="alphanix-footer__subscribe-btn"
                name="commit"
                aria-label="{{ block.settings.button_label }}"
              >
                {{ block.settings.button_label }}
              </button>
              {%- if form.errors -%}
                <p class="alphanix-footer__form-message alphanix-footer__form-message--error" id="ContactFooter-error">
                  {{- form.errors.translated_fields.email | capitalize }}
                  {{ form.errors.messages.email -}}
                </p>
              {%- endif -%}
              {%- if form.posted_successfully? -%}
                <p
                  class="alphanix-footer__form-message alphanix-footer__form-message--success"
                  id="ContactFooter-success"
                  tabindex="-1"
                  autofocus
                >
                  {{- 'newsletter.success' | t }}
                </p>
              {%- endif -%}
            {%- endform -%}
          </div>

        {%- when 'image' -%}
          <div class="alphanix-footer__col {{ block.settings.alignment }}" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {%- assign image_size_2x = block.settings.image_width | times: 2 | at_most: 5760 -%}
              <div style="max-width: min(100%, {{ block.settings.image_width }}px);">
                <img
                  srcset="{{ block.settings.image | image_url: width: block.settings.image_width }}, {{ block.settings.image | image_url: width: image_size_2x }} 2x"
                  src="{{ block.settings.image | image_url: width: 760 }}"
                  alt="{{ block.settings.image.alt | escape }}"
                  loading="lazy"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                >
              </div>
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
            {%- endif -%}
          </div>

      {%- endcase -%}
    {%- endfor -%}

  </div>

  {%- if section.settings.enable_country_selector and localization.available_countries.size > 1
    or section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
    <div class="alphanix-footer__localization">
      {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
        <localization-form>
          {%- form 'localization', id: 'FooterCountryForm', class: 'localization-form' -%}
            <div>
              <h2 class="caption-large text-body" id="FooterCountryLabel">{{ 'localization.country_label' | t }}</h2>
              {%- render 'country-localization', localPosition: 'FooterCountry' -%}
            </div>
          {%- endform -%}
        </localization-form>
      {%- endif -%}
      {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
        <localization-form>
          {%- form 'localization', id: 'FooterLanguageForm', class: 'localization-form' -%}
            <div>
              <h2 class="caption-large text-body" id="FooterLanguageLabel">{{ 'localization.language_label' | t }}</h2>
              {%- render 'language-localization', localPosition: 'FooterLanguage' -%}
            </div>
          {%- endform -%}
        </localization-form>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="alphanix-footer__bottom">
    <small class="alphanix-footer__copyright">
      &copy; {{ 'now' | date: '%Y' }} ALPHANIX. All rights reserved.
    </small>
    <div class="alphanix-footer__bottom-right">
      {%- if section.settings.show_policy -%}
        <ul class="alphanix-footer__policies">
          {%- for policy in shop.policies -%}
            {%- if policy != blank -%}
              <li><a href="{{ policy.url }}">{{ policy.title | escape }}</a></li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}
      {%- if section.settings.payment_enable -%}
        <div class="footer__payment">
          <span class="visually-hidden">{{ 'sections.footer.payment' | t }}</span>
          <ul class="list list-payment" role="list">
            {%- for type in shop.enabled_payment_types -%}
              <li class="list-payment__item">
                {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    </div>
  </div>

</footer>

<script>
  (function () {
    function initFooterAccordions() {
      document.querySelectorAll('#shopify-section-{{ section.id }} .alphanix-footer__col--links .alphanix-footer__col-heading').forEach(function (heading) {
        heading.addEventListener('click', function () {
          if (window.innerWidth >= 600) return;
          heading.closest('.alphanix-footer__col--links').classList.toggle('is-open');
        });
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initFooterAccordions);
    } else {
      initFooterAccordions();
    }
  })();
</script>

{% schema %}
{
  "name": "t:sections.footer.name",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "t:sections.footer.blocks.link_list.settings.heading.default",
          "label": "t:sections.footer.blocks.link_list.settings.heading.label"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "t:sections.footer.blocks.link_list.settings.menu.label",
          "info": "Manage links under Online Store › Navigation."
        },
        {
          "type": "checkbox",
          "id": "default_open",
          "label": "Expanded on mobile by default",
          "default": false,
          "info": "When enabled this section will be open (not collapsed) when the page first loads on mobile."
        }
      ]
    },
    {
      "type": "brand_information",
      "name": "t:sections.footer.blocks.brand_information.name",
      "settings": [
        {
          "type": "paragraph",
          "content": "t:sections.footer.blocks.brand_information.settings.paragraph.content"
        },
        {
          "type": "checkbox",
          "id": "show_social",
          "default": true,
          "label": "t:sections.footer.blocks.brand_information.settings.show_social.label",
          "info": "t:sections.footer.blocks.brand_information.settings.show_social.info"
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.footer.blocks.text.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "t:sections.footer.blocks.text.settings.heading.default",
          "label": "t:sections.footer.blocks.text.settings.heading.label"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "default": "t:sections.footer.blocks.text.settings.subtext.default",
          "label": "t:sections.footer.blocks.text.settings.subtext.label"
        },
        {
          "type": "checkbox",
          "id": "show_social",
          "default": false,
          "label": "Show social icons"
        },
        {
          "type": "checkbox",
          "id": "default_open",
          "label": "Expanded on mobile by default",
          "default": false,
          "info": "When enabled this section will be open (not collapsed) when the page first loads on mobile."
        }
      ]
    },
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "range",
          "id": "image_width",
          "min": 50,
          "max": 550,
          "step": 5,
          "unit": "px",
          "label": "Width",
          "default": 100
        },
        {
          "type": "select",
          "id": "alignment",
          "label": "Alignment",
          "options": [
            { "value": "", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "center"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Join our ALPHANIX family.",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "default": "<p>Get exclusive offers and updates.</p>",
