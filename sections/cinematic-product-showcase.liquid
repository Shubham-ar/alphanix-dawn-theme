},
{
"type":"range",
"id":"overlay_opacity",
"min": 0,
"max": 100,
"step": 5,
"unit": "%",
"label":"Overlay opacity",
"default": 40
},
{
"type":"select",
"id":"gradient_direction",
"label":"Gradient direction",
"options":[
{"value":"to bottom","label":"Top to bottom"},
{"value":"to top","label":"Bottom to top"},
{"value":"to right","label":"Left to right"},
{"value":"to left","label":"Right to left"}
],
"default":"to bottom"
},
{
"type":"color",
"id":"gradient_color_1",
"label":"Gradient start color",
"default":"#000000"
},
{
"type":"color",
"id":"gradient_color_2",
"label":"Gradient end color",
"default":"rgba(0,0,0,0)"
},
{
"type":"header",
"content":"Typography"
},
{
"type":"text",
"id":"heading",
"default":"Oversized Heavyweight Tee",
"label":"Heading"
},
{
"type":"select",
"id":"heading_size",
"options": [
  { "value": "h2", "label": "Small" },
  { "value": "h1", "label": "Medium" },
  { "value": "h0", "label": "Large" },
  { "value": "hxl", "label": "Extra Large" }
],
"default": "h1",
"label":"Heading size"
},
{
"type":"checkbox",
"id":"heading_uppercase",
"label":"Heading uppercase",
"default": false
},
{
"type":"textarea",
"id":"description",
"default":"Built for strength. Designed for everyday performance.",
