{% assign section_id = section.id | replace: '_', '' | downcase %}

<section id="cinematic-{{ section_id }}" class="cinematic-section" style="height: {{ section.settings.section_height }}">

  <div class="cinematic-bg">

    {% if section.settings.video != blank %}
      <video autoplay muted loop playsinline class="cinematic-media">
        <source src="{{ section.settings.video }}" type="video/mp4">
      </video>
    {% elsif section.settings.image != blank %}
      <img
        src="{{ section.settings.image | image_url: width: 2000 }}"
        class="cinematic-media"
        loading="lazy"
        width="2000"
        height="{{ 2000 | divided_by: section.settings.image.aspect_ratio | round }}"
      >
    {% endif %}

  </div>

  <div class="cinematic-overlay-{{ section_id }}"></div>

  <div class="cinematic-content {{ section.settings.desktop_position }} mobile-{{ section.settings.mobile_position }}">
    <div class="cinematic-text">

      <h2 class="cinematic-heading-{{ section_id }}">{{ section.settings.heading }}</h2>

      <div class="cinematic-description-{{ section_id }}">{{ section.settings.description }}</div>

      {% if section.settings.button_label != blank %}
      <a href="{{ section.settings.button_link }}" class="button cinematic-btn-{{ section_id }}">
        {{ section.settings.button_label }}
      </a>
      {% endif %}

    </div>
  </div>

</section>


{% style %}

.cinematic-section{
  position:relative;
  overflow:hidden;
  width:100%;
}

.cinematic-bg{
  position:absolute;
  inset:0;
  height:120%;
  will-change:transform;
}

.cinematic-media{
  width:100%;
  height:100%;
  object-fit:cover;
}

.cinematic-overlay-{{ section_id }}{
  position:absolute;
  inset:0;
  {% if section.settings.enable_overlay_gradient %}
    background: linear-gradient(
      {{ section.settings.gradient_direction }},
      {{ section.settings.gradient_color_1 }} 0%,
      {{ section.settings.gradient_color_2 }} 100%
    );
  {% else %}
    background-color: rgba(0,0,0,0.3);
  {% endif %}
  opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  z-index: 1;
}

.cinematic-content{
  position:absolute;
  max-width: {{ section.settings.content_max_width }}px;
  color: {{ section.settings.text_color }};
  padding:60px;
  z-index: 2;
  width: 100%;
}

.cinematic-text{
  opacity:0;
  transform:translateY(40px);
  transition:all .8s ease;
  text-align: {{ section.settings.text_alignment }};
}

.cinematic-section.visible .cinematic-text{
  opacity:1;
  transform:translateY(0);
}

.cinematic-heading-{{ section_id }}{
  color: {{ section.settings.text_color }};
  font-size: calc({{ section.settings.heading_size }}px * {{ settings.heading_scale | divided_by: 100.0 }});
  margin-bottom:16px;
  letter-spacing:-0.5px;
  line-height: 1.1;
  {% if section.settings.heading_uppercase %}
    text-transform: uppercase;
  {% endif %}
  {% if section.settings.enable_text_shadow %}
    text-shadow: {{ section.settings.text_shadow_horizontal }}px {{ section.settings.text_shadow_vertical }}px {{ section.settings.text_shadow_blur }}px {{ section.settings.text_shadow_color }};
  {% endif %}
}

.cinematic-description-{{ section_id }}{
  color: {{ section.settings.text_color }};
  font-size: calc({{ section.settings.description_size }}px * {{ settings.body_scale | divided_by: 100.0 }});
  line-height:1.5;
  margin-bottom:24px;
  {% if section.settings.description_uppercase %}
    text-transform: uppercase;
  {% endif %}
  {% if section.settings.enable_text_shadow %}
    text-shadow: {{ section.settings.text_shadow_horizontal }}px {{ section.settings.text_shadow_vertical }}px {{ section.settings.text_shadow_blur }}px {{ section.settings.text_shadow_color }};
  {% endif %}
}

.cinematic-btn-{{ section_id }}{
  display: inline-block;
  font-weight:600;
  background-color: {{ section.settings.button_background_color }};
  color: {{ section.settings.button_text_color }};
  border-color: {{ section.settings.button_border_color }};
  font-size: {{ section.settings.button_font_size }}px;
  padding: 1.4rem 3.2rem;
  transition: all 0.3s ease;
  {% if section.settings.button_uppercase %}
    text-transform: uppercase;
  {% endif %}
}

.cinematic-btn-{{ section_id }}:hover {
  background-color: {{ section.settings.button_hover_background }};
  color: {{ section.settings.button_hover_text }};
  transform: translateY(-2px);
}

/* POSITIONS */

.left-center{ top:50%; left:6%; transform:translateY(-50%); }
.right-center{ top:50%; right:6%; transform:translateY(-50%); }
.bottom-left{ bottom:8%; left:6%; }
.bottom-right{ bottom:8%; right:6%; }
.center{ top:50%; left:50%; transform:translate(-50%,-50%); text-align:center; }

@media screen and (max-width: 989px) {
  .cinematic-heading-{{ section_id }}{
    font-size: calc({{ section.settings.heading_size | times: 0.8 }}px * {{ settings.heading_scale | divided_by: 100.0 }});
  }
}

@media(max-width:768px){

  .cinematic-section{
    height: {{ section.settings.mobile_height }}vh !important;
  }

  .cinematic-content{
    left:0;
    right:0;
    padding:24px;
    max-width: 100%;
  }

  .cinematic-text{
    text-align: center;
  }

  .mobile-bottom-left { bottom: 8%; left: 6%; transform: none; }
  .mobile-bottom-center { bottom: 8%; left: 50%; transform: translateX(-50%); }
  .mobile-bottom-right { bottom: 8%; right: 6%; transform: none; }
  .mobile-top-right { top: 8%; right: 6%; transform: none; }
  .mobile-center { top: 50%; left: 50%; transform: translate(-50%, -50%); }

  .cinematic-heading-{{ section_id }}{
    font-size: calc({{ section.settings.heading_size | times: 0.65 }}px * {{ settings.heading_scale | divided_by: 100.0 }});
  }

}

{% endstyle %}


<script>
{
  const sectionId = "{{ section_id }}";
  const cinematicSections = document.querySelectorAll('#cinematic-' + sectionId);

  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if(entry.isIntersecting){
        entry.target.classList.add('visible');
      }
    });
  },{threshold:0.3});

  cinematicSections.forEach(section=>{
    observer.observe(section);
  });


  window.addEventListener("scroll",()=>{
    cinematicSections.forEach(section=>{
      const bg = section.querySelector(".cinematic-bg");
      if (!bg) return;
      const rect = section.getBoundingClientRect();
      const speed = 0.25;
      const offset = rect.top * speed;
      bg.style.transform = `translate3d(0, ${offset}px, 0)`;
    });
  });
}
</script>


