  { "value": "subtitle", "label": "Subtitle" },
  { "value": "uppercase", "label": "Uppercase" }
],
"default": "body",
"label": "Description style"
},
{
"type":"checkbox",
"id":"description_uppercase",
"label":"Description uppercase",
"default": false
},
{
"type":"header",
"content":"Colors"
},
{
"type":"color",
